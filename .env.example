# ─── App ──────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────
# ใช้ "db" เมื่อรันผ่าน Docker Compose
# ใช้ "localhost" เมื่อรันบน local โดยตรง
DB_HOST=db
DB_PORT=3306
DB_NAME=webdb
DB_USER=root
DB_PASSWORD=root

# ─── JWT ──────────────────────────────────
# ⚠️ เปลี่ยน JWT_SECRET เป็นค่าที่ปลอดภัยก่อน deploy production
JWT_SECRET=never-gonna-give-you-up-never-gonna-let-you-down
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────
# คั่นหลาย origins ด้วย comma: http://localhost:3000,https://yourdomain.com
# ใช้ * เพื่อเปิดให้ทุก origin (ไม่แนะนำใน production)
ALLOWED_ORIGINS=*
